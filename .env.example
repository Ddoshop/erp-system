PORT=3000
JWT_SECRET=change_this_secret_in_production

# Email (nodemailer) — настройте для отправки напоминаний по дедлайнам
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@yourdomain.ru
SMTP_PASS=your_password
SMTP_FROM="ТехноТрейд ERP <no-reply@yourdomain.ru>"
SMTP_IGNORE_TLS=false
SMTP_ALLOW_SELF_SIGNED=false

# Домен и параметры web-mail в ERP
MAIL_DOMAIN=guserv.online
MAIL_UNSUBSCRIBE_EMAIL=unsubscribe@guserv.online
MAIL_UNSUBSCRIBE_URL=https://guserv.online/unsubscribe

# Входящая почта (IMAP polling)
MAIL_RECV_ENABLED=false
MAIL_RECV_PROTOCOL=imap
MAIL_RECV_POLL_MS=120000
MAIL_RECV_CATCHALL_TO=
IMAP_ACCOUNTS_FILE=/etc/dovecot/erp-imap-accounts.json

IMAP_HOST=imap.yandex.ru
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=no-reply@yourdomain.ru
IMAP_PASS=your_password
IMAP_FOLDER=INBOX
IMAP_TLS_REJECT_UNAUTHORIZED=true

# Количество дней до дедлайна для отправки напоминания
REMINDER_DAYS=3
